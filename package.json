{
  "name": "netrue-limited-backend",
  "version": "1.0.0",
  "description": "Production-ready backend API for Netrue Limited",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongoose": "^8.9.2",
    "nodemailer": "^7.0.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src"
    ],
    "ext": "js,json"
  }
}
